generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OperationType {
  REGISTER
  LOGIN
  LOGOUT
  UPLOAD
  DOWNLOAD
  DELETE
  RESTORE
  RENAME
  SHARE_CREATE
  SHARE_ACCESS
  SHARE_DELETE
}

model User {
  id           Int            @id @default(autoincrement())
  username     String         @unique @db.VarChar(50)
  passwordHash String         @db.VarChar(255)
  email        String?        @unique @db.VarChar(255)
  status       UserStatus     @default(ACTIVE)
  storageLimit BigInt         @default(5368709120)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  files        File[]
  sessions     Session[]
  operationLogs OperationLog[]
  shares       Share[]

  @@index([username])
  @@index([email])
  @@map("users")
}

model File {
  id          Int       @id @default(autoincrement())
  userId      Int
  fileName    String    @db.VarChar(255)
  fileSize    BigInt
  fileType    String    @db.VarChar(100)
  storagePath String    @db.VarChar(500)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares Share[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, fileName])
  @@map("files")
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @db.VarChar(255)
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("sessions")
}

model OperationLog {
  id             Int           @id @default(autoincrement())
  userId         Int
  operationType  OperationType
  targetResource String?       @db.VarChar(500)
  ipAddress      String?       @db.VarChar(45)
  details        String?       @db.Text
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([operationType])
  @@index([createdAt])
  @@map("operation_logs")
}

model Share {
  id        Int       @id @default(autoincrement())
  fileId    Int
  userId    Int
  shareCode String    @unique @db.Char(12)
  password  String?   @db.VarChar(255)
  maxViews  Int?      @default(100)
  viewCount Int       @default(0)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shareCode])
  @@index([userId])
  @@index([fileId])
  @@index([expiresAt])
  @@map("shares")
}